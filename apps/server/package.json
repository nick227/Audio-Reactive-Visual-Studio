{
  "name": "server",
  "version": "0.0.1",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "prebuild": "pnpm --filter @avl/db build",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@avl/db": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^3.1.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.29.0",
    "fastify-openapi-glue": "^4.7.0",
    "google-auth-library": "^9.15.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.0"
  }
}
