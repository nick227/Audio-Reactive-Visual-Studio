# Database (MySQL 8.0+)
DATABASE_URL=mysql://root:password@localhost:3306/avl_dev

# Server
PORT=3001
SESSION_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# App base URL — used to construct password reset links sent via email
APP_URL=http://localhost:5173

# Seed — admin user bootstrapped by `pnpm db:seed`
ADMIN_EMAIL=admin@example.com
ADMIN_DISPLAY_NAME=Admin

# AI Transcription
OPENAI_API_KEY=sk-...           # Required for Whisper transcription
# AUDIOSHAKE_API_KEY=           # Future: AudioShake lyric alignment

# Cloudflare R2 (Phase 2 — leave blank until R2 is wired)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Web app
VITE_API_URL=http://localhost:3001
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
