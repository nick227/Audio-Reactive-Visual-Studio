{
  "name": "audio-visual-layer",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "pnpm --recursive lint",
    "test": "pnpm --recursive test",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "sdk:generate": "pnpm --filter @avl/sdk generate",
    "sdk:check": "tsx scripts/check-sdk-drift.ts",
    "test:generate": "tsx scripts/generate-tests.ts",
    "db:push": "pnpm --filter @avl/db db:push",
    "db:seed": "pnpm --filter @avl/db db:seed",
    "db:studio": "pnpm --filter @avl/db db:studio"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  }
}
